# Database
DATABASE_URL=postgresql+asyncpg://riskdash:riskdash@localhost:5432/riskdash
DATABASE_URL_SYNC=postgresql://riskdash:riskdash@localhost:5432/riskdash

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
LOG_LEVEL=INFO

# Data
TICKERS=^GSPC,GLE.PA,SIE.DE
FX_PAIR=EURUSD=X
BASE_CURRENCY=EUR
BACKFILL_YEARS=5

# Scheduling (cron-style)
# After US market close — 22:15 CET
INGESTION_CRON_HOUR=22
INGESTION_CRON_MINUTE=15
